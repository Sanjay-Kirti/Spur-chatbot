# Required: Your Groq API key (free at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Optional: Server port (default: 3001)
PORT=3001

# Optional: SQLite database file path (default: ./data/chat.db)
DATABASE_PATH=./data/chat.db

# Optional: Max tokens for LLM responses (default: 500)
MAX_TOKENS=500

# Optional: Max allowed message length from users (default: 2000)
MAX_MESSAGE_LENGTH=2000

# Optional: Max conversation history messages sent to LLM (default: 20)
MAX_HISTORY_MESSAGES=20

# Optional: Frontend URL for CORS (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Optional: Environment (default: development)
NODE_ENV=development

# ===== Frontend =====
# Optional: Backend API URL (default: http://localhost:3001)
VITE_API_URL=http://localhost:3001
